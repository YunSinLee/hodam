{
  "name": "hodam",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --ext .ts,.tsx --max-warnings=0",
    "test": "vitest run --maxWorkers=1 --no-file-parallelism",
    "test:watch": "vitest --maxWorkers=1 --no-file-parallelism",
    "test:smoke:v1": "node scripts/smoke-v1.mjs",
    "test:user:ensure": "node scripts/ensure-test-user.mjs",
    "token:test:access": "node scripts/get-test-access-token.mjs",
    "check:env": "node scripts/check-env.mjs",
    "check:env:strict": "node scripts/check-env.mjs --strict",
    "check:audit:prod": "npm audit --omit=dev",
    "check:audit:all": "npm audit",
    "check:oauth": "node scripts/check-oauth.mjs",
    "check:post-upgrade": "node scripts/check-post-upgrade.mjs",
    "check:threads:local": "node scripts/check-threads-local.mjs",
    "check:supabase:security": "node scripts/check-supabase-security.mjs",
    "check:supabase:security:strict": "node scripts/check-supabase-security.mjs --strict",
    "check:supabase:security:strict:free": "HODAM_SUPABASE_SECURITY_IGNORE_LINTS=auth_leaked_password_protection,missing_service_role_key node scripts/check-supabase-security.mjs --strict",
    "check:supabase:security:strict:baseline": "HODAM_SUPABASE_SECURITY_IGNORE_LINTS=auth_leaked_password_protection,vulnerable_postgres_version,missing_service_role_key,missing_management_credentials npm run check:supabase:security:strict",
    "check:supabase:security:strict:post-upgrade": "HODAM_SUPABASE_SECURITY_IGNORE_LINTS=auth_leaked_password_protection,missing_service_role_key,missing_management_credentials npm run check:supabase:security:strict",
    "check:kpi": "node scripts/check-kpi.mjs",
    "check:all": "npm run check:env && npm run check:audit:prod && npm run lint && npm run test && npm run build",
    "check:release:gate": "OPENAI_API_KEY=dummy npm run check:all && npm run check:supabase:security:strict:baseline",
    "supabase:auth:harden": "node scripts/harden-supabase-auth.mjs",
    "supabase:auth:harden:apply": "node scripts/harden-supabase-auth.mjs --apply",
    "test:e2e:auth:local": "node scripts/e2e-auth-local.mjs",
    "mock:toss": "node scripts/mock-toss-server.mjs",
    "test:e2e:payments:local": "node scripts/e2e-payments-local.mjs",
    "postbuild": "next-sitemap"
  },
  "dependencies": {
    "@next/third-parties": "^15.5.14",
    "@sentry/nextjs": "^10.47.0",
    "@supabase/supabase-js": "^2.39.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.10",
    "next": "^15.5.14",
    "next-sitemap": "^4.2.3",
    "openai": "^4.60.0",
    "primeicons": "^7.0.0",
    "primereact": "^10.8.3",
    "react": "^18",
    "react-dom": "^18",
    "sass": "^1.71.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.50",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.2.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-next": "^15.5.14",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-prettier": "^5.1.2",
    "eslint-plugin-react": "^7.28.0",
    "eslint-plugin-react-hooks": "^4.3.0",
    "postcss": "^8.4.35",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
