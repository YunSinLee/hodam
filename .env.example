# Public (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback
# Optional: runtime origin hint for oauth diagnostics script
# HODAM_RUNTIME_ORIGIN=http://localhost:3000

# AI (required: set one of OPENAI_API_KEY or OPEN_AI_API_KEY)
OPENAI_API_KEY=your-openai-api-key
# OPEN_AI_API_KEY=legacy-openai-api-key

# Supabase server/admin (recommended, required for admin/webhook flows)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Optional: allow fallback to user-scoped server client when service role key is missing.
# Default behavior is enabled in development, disabled in production.
# HODAM_ALLOW_ADMIN_FALLBACK=true
# Optional for Management API based advisor checks
SUPABASE_ACCESS_TOKEN=your-supabase-personal-access-token
SUPABASE_PROJECT_REF=your-project-ref
# Optional auth hardening targets (defaults: otp=3600, hibp=true)
# HODAM_AUTH_MAILER_OTP_EXP=3600
# HODAM_AUTH_PASSWORD_HIBP_ENABLED=true
# Optional: security check ignore list (comma-separated lint/issue names)
# e.g. auth_leaked_password_protection,missing_service_role_key
# HODAM_SUPABASE_SECURITY_IGNORE_LINTS=

# Payments (recommended when using Toss)
TOSS_PAYMENTS_SECRET_KEY=your-toss-secret-key
TOSS_PAYMENTS_WEBHOOK_SECRET=your-toss-webhook-secret
TOSS_PAYMENTS_WEBHOOK_HMAC_SECRET=your-toss-webhook-hmac-secret
NEXT_PUBLIC_TOSS_PAYMENTS_CLIENT_KEY=your-toss-client-key
# Optional for local/integration testing (default: https://api.tosspayments.com)
# TOSS_PAYMENTS_API_BASE_URL=http://localhost:4010
# Optional webhook signature header controls (defaults shown)
# TOSS_PAYMENTS_WEBHOOK_SIGNATURE_HEADER=x-toss-signature
# TOSS_PAYMENTS_WEBHOOK_SIGNATURE_PREFIX=
# TOSS_PAYMENTS_WEBHOOK_SIGNATURE_ENCODING=hex

# Optional quotas
HODAM_DAILY_AI_COST_LIMIT=120
HODAM_DAILY_TTS_CHAR_LIMIT=30000

# Optional observability
SENTRY_DSN=https://<public-key>@o000000.ingest.sentry.io/0000000
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Optional test auth for smoke/e2e
# HODAM_TEST_ACCESS_TOKEN=your-access-token
# HODAM_TEST_USER_EMAIL=test-user@example.com
# HODAM_TEST_USER_PASSWORD=test-user-password
